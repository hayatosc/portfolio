---
interface Props {
	class?: string
	href?: string
}

const { class: className, href } = Astro.props
---

{href ? (
	<a href={href} class:list={['card', className]}>
		<slot />
	</a>
) : (
	<div class:list={['card', className]}>
		<slot />
	</div>
)}

<style>
.card {
	background: var(--color-bg-card);
	border: 1px solid var(--color-border);
	border-radius: 12px;
	overflow: hidden;
}
</style>
