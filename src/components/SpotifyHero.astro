---
import { Image } from 'astro:assets'
// Spotify-style self-introduction hero component
// Desktop: phone-sized card centered on screen
// Mobile: full-screen
import type { ImageMetadata } from 'astro'

interface Props {
	name: string
	job: string
	bio: string
	github: string
	linkedin: string
	email: string
	website: string
	photo: ImageMetadata
	startYear: string
}

const { name, job, bio, github, linkedin, email, website, photo, startYear } =
	Astro.props
---

<section class="spotify-wrapper">
	<div class="spotify-card">
		<!-- Nav bar -->
		<div class="spotify-nav">
			<button type="button" class="nav-btn" aria-label="Back">
				<svg
					aria-hidden="true"
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="m6 9 6 6 6-6" />
				</svg>
			</button>
			<span class="now-playing-label">Now Playing</span>
			<button type="button" class="nav-btn" aria-label="More options">
				<svg
					aria-hidden="true"
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<circle cx="12" cy="12" r="1" />
					<circle cx="19" cy="12" r="1" />
					<circle cx="5" cy="12" r="1" />
				</svg>
			</button>
		</div>

		<!-- Artwork -->
		<div class="artwork-wrapper">
			<Image class="artwork" src={photo} alt={name} />
		</div>

		<!-- Song info row -->
		<div class="song-row">
			<div class="song-left">
				<p class="song-title">{name}</p>
				<p class="artist">{job}</p>
				<p class="bio-text">{bio}</p>
			</div>
			<div class="check-badge" aria-label="Following">
				<svg
					aria-hidden="true"
					width="18"
					height="18"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="3"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M20 6 9 17l-5-5" />
				</svg>
			</div>
		</div>

		<!-- Progress section -->
		<div class="progress-section">
			<div
				class="progress-track"
				role="progressbar"
				aria-valuenow="40"
				aria-valuemin="0"
				aria-valuemax="100"
			>
				<div class="progress-bg"></div>
				<div class="progress-fill"></div>
				<div class="progress-dot"></div>
			</div>
			<div class="time-row">
				<span>{startYear}</span>
				<span>Present</span>
			</div>
		</div>

		<!-- Controls: social links around play button -->
		<div class="controls-row">
			<a
				href={github}
				class="social-btn"
				aria-label="GitHub"
				target="_blank"
				rel="noopener noreferrer"
			>
				<svg
					aria-hidden="true"
					width="26"
					height="26"
					viewBox="0 0 24 24"
					fill="currentColor"
				>
					<path
						d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.933.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.744 0 .267.18.578.688.48C19.138 20.167 22 16.42 22 12c0-5.523-4.477-10-10-10z"
					/>
				</svg>
			</a>

			<a
				href={linkedin}
				class="social-btn"
				aria-label="LinkedIn"
				target="_blank"
				rel="noopener noreferrer"
			>
				<svg
					aria-hidden="true"
					width="26"
					height="26"
					viewBox="0 0 24 24"
					fill="currentColor"
				>
					<path
						d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
					/>
				</svg>
			</a>

			<div class="play-btn" aria-label="Now playing">
				<svg
					aria-hidden="true"
					width="26"
					height="26"
					viewBox="0 0 24 24"
					fill="currentColor"
				>
					<polygon points="5 3 19 12 5 21 5 3" />
				</svg>
			</div>

			<a href={email} class="social-btn" aria-label="Email">
				<svg
					aria-hidden="true"
					width="26"
					height="26"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<rect width="20" height="16" x="2" y="4" rx="2" />
					<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
				</svg>
			</a>

			<a
				href={website}
				class="social-btn"
				aria-label="Website"
				target="_blank"
				rel="noopener noreferrer"
			>
				<svg
					aria-hidden="true"
					width="26"
					height="26"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<circle cx="12" cy="12" r="10" />
					<path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
					<path d="M2 12h20" />
				</svg>
			</a>
		</div>
	</div>
</section>

<style>
.spotify-wrapper {
	display: flex;
	align-items: center;
	justify-content: center;
	padding: 3rem 1.5rem;

	@media (max-width: 480px) {
		padding: 0;
		min-height: 100svh;
		align-items: stretch;
	}
}

.spotify-card {
	width: 393px;
	height: 852px;
	background: linear-gradient(180deg, #3a8fa0 0%, #1a4a55 45%, #1a2a2e 100%);
	display: flex;
	flex-direction: column;
	font-family: "Inter", system-ui, -apple-system, sans-serif;
	color: #ffffff;
	border-radius: 54px;
	overflow: hidden;
	box-shadow:
		0 48px 96px rgba(0, 0, 0, 0.6),
		0 0 0 1px rgba(255, 255, 255, 0.08);

	@media (max-width: 480px) {
		width: 100%;
		height: 100svh;
		border-radius: 0;
		box-shadow: none;
	}
}

/* Nav */
.spotify-nav {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 20px 20px 0;
	height: 56px;
}

.nav-btn {
	background: none;
	border: none;
	color: #ffffff;
	cursor: pointer;
	padding: 4px;
	display: flex;
	align-items: center;
	opacity: 0.8;
}

.now-playing-label {
	font-size: 14px;
	font-weight: 600;
	letter-spacing: 0.3px;
}

/* Artwork */
.artwork-wrapper {
	flex: 1;
	display: flex;
	align-items: center;
	padding: 16px 20px;

	@media (max-width: 480px) {
		padding: 12px 16px;
	}
}

.artwork {
	width: 100%;
	aspect-ratio: 1 / 1;
	object-fit: cover;
	border-radius: 8px;
	box-shadow: 0 12px 32px rgba(0, 0, 0, 0.55);
	display: block;
}

/* Song info */
.song-row {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 12px;
	padding: 16px 24px;
}

.song-left {
	display: flex;
	flex-direction: column;
	gap: 4px;
	flex: 1;
	min-width: 0;
}

.song-title {
	font-size: 22px;
	font-weight: 700;
	color: #ffffff;
	line-height: 1.2;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.artist {
	font-size: 14px;
	color: #b3b3b3;
	font-weight: 400;
}

.bio-text {
	font-size: 11px;
	color: #6a6a6a;
	font-weight: 400;
}

.check-badge {
	width: 32px;
	height: 32px;
	border-radius: 50%;
	background: #1db954;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
	color: #000000;
}

/* Progress */
.progress-section {
	padding: 0 24px 8px;
	display: flex;
	flex-direction: column;
	gap: 8px;
}

.progress-track {
	position: relative;
	height: 12px;
	display: flex;
	align-items: center;
}

.progress-bg {
	position: absolute;
	left: 0;
	right: 0;
	height: 4px;
	background: #535353;
	border-radius: 2px;
}

.progress-fill {
	position: absolute;
	left: 0;
	width: 40%;
	height: 4px;
	background: #1db954;
	border-radius: 2px;
}

.progress-dot {
	position: absolute;
	left: calc(40% - 6px);
	width: 12px;
	height: 12px;
	background: #1db954;
	border-radius: 50%;
}

.time-row {
	display: flex;
	justify-content: space-between;
	font-size: 12px;
	color: #b3b3b3;
}

/* Controls */
.controls-row {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 4px 24px 36px;
	height: 88px;

	@media (max-width: 480px) {
		padding-bottom: max(36px, env(safe-area-inset-bottom, 36px));
	}
}

.social-btn {
	color: #ffffff;
	display: flex;
	align-items: center;
	justify-content: center;
	text-decoration: none;
	transition: opacity 150ms ease;

	&:hover {
		opacity: 0.65;
	}
}

.play-btn {
	width: 64px;
	height: 64px;
	border-radius: 50%;
	background: #ffffff;
	display: flex;
	align-items: center;
	justify-content: center;
	color: #000000;
	flex-shrink: 0;

	& svg {
		margin-left: 3px;
	}
}
</style>
