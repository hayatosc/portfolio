---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import {
	Check,
	ChevronDown,
	Ellipsis,
	Github,
	Globe,
	Mail,
	Play,
	Twitter,
} from 'lucide-astro'

interface Props {
	name: string
	job: string
	bio: string
	github: string
	twitter: string
	email: string
	website: string
	photo: ImageMetadata
	startYear: string
}

const { name, job, bio, github, twitter, email, website, photo, startYear } =
	Astro.props
---

<section class="spotify-wrapper">
	<div class="spotify-card">
		<!-- Nav bar -->
		<div class="spotify-nav">
			<button type="button" class="nav-btn" aria-label="Back">
				<ChevronDown aria-hidden="true" size={24} />
			</button>
			<span class="now-playing-label">Now Playing</span>
			<button type="button" class="nav-btn" aria-label="More options">
				<Ellipsis aria-hidden="true" size={24} />
			</button>
		</div>

		<!-- Artwork -->
		<div class="artwork-wrapper">
			<Image class="artwork" src={photo} alt={name} />
		</div>

		<!-- Song info row -->
		<div class="song-row">
			<div class="song-left">
				<p class="song-title">{name}</p>
				<p class="artist">{job}</p>
				<p class="bio-text">{bio}</p>
			</div>
			<div class="check-badge" aria-label="Following">
				<Check aria-hidden="true" size={18} stroke-width={3} />
			</div>
		</div>

		<!-- Progress section -->
		<div class="progress-section">
			<div
				class="progress-track"
				role="progressbar"
				aria-valuenow="40"
				aria-valuemin="0"
				aria-valuemax="100"
			>
				<div class="progress-bg"></div>
				<div class="progress-fill"></div>
				<div class="progress-dot"></div>
			</div>
			<div class="time-row">
				<span>{startYear}</span>
				<span>Present</span>
			</div>
		</div>

		<!-- Controls: social links around play button -->
		<div class="controls-row">
			<a
				href={github}
				class="social-btn"
				aria-label="GitHub"
				target="_blank"
				rel="noopener noreferrer"
			>
				<Github aria-hidden="true" size={26} />
			</a>

			<a
				href={twitter}
				class="social-btn"
				aria-label="X (Twitter)"
				target="_blank"
				rel="noopener noreferrer"
			>
				<Twitter aria-hidden="true" size={26} />
			</a>

			<div class="play-btn" aria-label="Now playing">
				<Play aria-hidden="true" size={26} fill="currentColor" />
			</div>

			<a href={email} class="social-btn" aria-label="Email">
				<Mail aria-hidden="true" size={26} />
			</a>

			<a
				href={website}
				class="social-btn"
				aria-label="Website"
				target="_blank"
				rel="noopener noreferrer"
			>
				<Globe aria-hidden="true" size={26} />
			</a>
		</div>
	</div>
</section>

<style>
.spotify-wrapper {
	display: flex;
	align-items: center;
	justify-content: center;
	padding: 3rem 1.5rem;

	@media (max-width: 480px) {
		padding: 0;
		min-height: 100svh;
		align-items: stretch;
	}
}

.spotify-card {
	width: 393px;
	height: 852px;
	background: #121212;
	display: flex;
	flex-direction: column;
	font-family: "Inter", system-ui, -apple-system, sans-serif;
	color: #ffffff;
	border-radius: 54px;
	overflow: hidden;
	box-shadow:
		0 48px 96px rgba(0, 0, 0, 0.6),
		0 0 0 1px rgba(255, 255, 255, 0.08);

	@media (max-width: 480px) {
		width: 100%;
		height: 100svh;
		border-radius: 0;
		box-shadow: none;
	}
}

/* Nav */
.spotify-nav {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 20px 20px 0;
	height: 56px;
}

.nav-btn {
	background: none;
	border: none;
	color: #ffffff;
	cursor: pointer;
	padding: 4px;
	display: flex;
	align-items: center;
	opacity: 0.8;
}

.now-playing-label {
	font-size: 14px;
	font-weight: 600;
	letter-spacing: 0.3px;
}

/* Artwork */
.artwork-wrapper {
	flex: 1;
	display: flex;
	align-items: center;
	padding: 16px 20px;

	@media (max-width: 480px) {
		padding: 12px 16px;
	}
}

.artwork {
	width: 100%;
	aspect-ratio: 1 / 1;
	object-fit: cover;
	border-radius: 8px;
	box-shadow: 0 12px 32px rgba(0, 0, 0, 0.55);
	display: block;
}

/* Song info */
.song-row {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 12px;
	padding: 16px 24px;
}

.song-left {
	display: flex;
	flex-direction: column;
	gap: 4px;
	flex: 1;
	min-width: 0;
}

.song-title {
	font-size: 22px;
	font-weight: 700;
	color: #ffffff;
	line-height: 1.2;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.artist {
	font-size: 14px;
	color: #b3b3b3;
	font-weight: 400;
}

.bio-text {
	font-size: 11px;
	color: #6a6a6a;
	font-weight: 400;
}

.check-badge {
	width: 32px;
	height: 32px;
	border-radius: 50%;
	background: #1db954;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
	color: #000000;
}

/* Progress */
.progress-section {
	padding: 0 24px 8px;
	display: flex;
	flex-direction: column;
	gap: 8px;
}

.progress-track {
	position: relative;
	height: 12px;
	display: flex;
	align-items: center;
}

.progress-bg {
	position: absolute;
	left: 0;
	right: 0;
	height: 4px;
	background: #535353;
	border-radius: 2px;
}

.progress-fill {
	position: absolute;
	left: 0;
	width: 40%;
	height: 4px;
	background: #1db954;
	border-radius: 2px;
}

.progress-dot {
	position: absolute;
	left: calc(40% - 6px);
	width: 12px;
	height: 12px;
	background: #1db954;
	border-radius: 50%;
}

.time-row {
	display: flex;
	justify-content: space-between;
	font-size: 12px;
	color: #b3b3b3;
}

/* Controls */
.controls-row {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 4px 24px 36px;
	height: 88px;

	@media (max-width: 480px) {
		padding-bottom: max(36px, env(safe-area-inset-bottom, 36px));
	}
}

.social-btn {
	color: #ffffff;
	display: flex;
	align-items: center;
	justify-content: center;
	text-decoration: none;
	transition: opacity 150ms ease;

	&:hover {
		opacity: 0.65;
	}
}

.play-btn {
	width: 64px;
	height: 64px;
	border-radius: 50%;
	background: #ffffff;
	display: flex;
	align-items: center;
	justify-content: center;
	color: #000000;
	flex-shrink: 0;

	& svg {
		margin-left: 3px;
	}
}
</style>
