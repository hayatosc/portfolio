---
import { BookOpen, Film, Github } from 'lucide-astro'

const musicTracks = [
	{ title: 'Electric Feel', artist: 'MGMT', size: 'large' },
	{ title: 'Midnight City', artist: 'M83', size: 'small' },
	{ title: 'Fluorescent Adolescent', artist: 'Arctic Monkeys', size: 'small' },
]

// GitHub contribution grid colors (5 rows × 7 cols)
const contributionColors = [
	['#161b22', '#0e4429', '#26a641', '#0e4429', '#161b22', '#39d353', '#26a641'],
	['#0e4429', '#006d32', '#39d353', '#26a641', '#0e4429', '#006d32', '#161b22'],
	['#26a641', '#39d353', '#006d32', '#0e4429', '#26a641', '#161b22', '#0e4429'],
	['#006d32', '#0e4429', '#26a641', '#39d353', '#0e4429', '#26a641', '#006d32'],
	['#161b22', '#26a641', '#0e4429', '#006d32', '#39d353', '#0e4429', '#26a641'],
]
---

<section class="activities">
	<div class="activities-header">
		<div class="accent-bar"></div>
		<h2 class="activities-title">RECENT<br>ACTIVITIES</h2>
	</div>

	<div class="bento-grid">
		<!-- Row 1: Music + Books/Films -->
		<div class="bento-row">
			<!-- Music card -->
			<div class="bento-card music-card">
				<p class="card-label">NOW LISTENING</p>
				<div class="track-list">
					{musicTracks.map(({ title, artist, size }, i) => (
						<>
							{i > 0 && <hr class="track-sep" />}
							<div class:list={['track', `track-${size}`]}>
								<div class:list={['track-art', `track-art-${size}`]}></div>
								<div class="track-info">
									<p class:list={['track-title', `track-title-${size}`]}>{title}</p>
									<p class="track-artist">{artist}</p>
								</div>
							</div>
						</>
					))}
				</div>
			</div>

			<!-- Right stack: Book + Film -->
			<div class="right-stack">
				<div class="bento-card media-card">
					<div class="media-thumb">
						<BookOpen size={22} aria-hidden="true" class="media-icon" />
					</div>
					<p class="card-label">BOOK</p>
					<p class="media-title">Klara and<br>the Sun</p>
					<p class="media-sub">Kazuo Ishiguro</p>
				</div>
				<div class="bento-card media-card">
					<div class="media-thumb">
						<Film size={22} aria-hidden="true" class="media-icon" />
					</div>
					<p class="card-label">FILM</p>
					<p class="media-title">Perfect Days</p>
					<p class="media-sub">Wim Wenders · 2023</p>
				</div>
			</div>
		</div>

		<!-- Row 2: Film + GitHub -->
		<div class="bento-row">
			<div class="bento-card media-card media-card--horiz">
				<div class="media-thumb">
					<Film size={22} aria-hidden="true" class="media-icon" />
				</div>
				<div>
					<p class="card-label">FILM</p>
					<p class="media-title">Drive My Car</p>
					<p class="media-sub">Ryusuke Hamaguchi · 2021</p>
				</div>
			</div>

			<!-- GitHub contributions -->
			<div class="bento-card github-card">
				<div class="github-header">
					<Github size={16} aria-hidden="true" class="github-icon" />
					<p class="card-label">GITHUB</p>
					<span class="github-handle">hayatosc</span>
				</div>
				<div class="contrib-grid" aria-label="GitHub contribution graph">
					{contributionColors.map((row) => (
						<div class="contrib-row">
							{row.map((color) => (
								<div class="contrib-dot" style={`background: ${color}`}></div>
							))}
						</div>
					))}
				</div>
			</div>
		</div>
	</div>
</section>

<style>
.activities {
	padding: 70px 80px;
	display: flex;
	flex-direction: column;
	gap: 40px;

	@media (max-width: 768px) {
		padding: 48px 24px;
	}
}

.activities-header {
	display: flex;
	flex-direction: column;
	gap: 8px;
}

.accent-bar {
	width: 60px;
	height: 4px;
	background: var(--color-fg);
	border-radius: 2px;
}

.activities-title {
	font-size: 34px;
	font-weight: 300;
	color: var(--color-fg);
	line-height: 0.95;
}

/* ── Bento Grid ── */
.bento-grid {
	display: flex;
	flex-direction: column;
	gap: 14px;
}

.bento-row {
	display: flex;
	gap: 14px;

	@media (max-width: 600px) {
		flex-direction: column;
	}
}

.bento-card {
	background: var(--color-bg-card);
	border: 1px solid var(--color-border);
	border-radius: 12px;
	padding: 20px;
}

.card-label {
	font-family: var(--font-mono);
	font-size: 10px;
	color: #444444;
	letter-spacing: 3px;
	text-transform: uppercase;
}

/* ── Music Card ── */
.music-card {
	flex: 1;
	display: flex;
	flex-direction: column;
	gap: 14px;
	padding: 24px;
}

.track-list {
	display: flex;
	flex-direction: column;
	gap: 0;
}

.track-sep {
	border: none;
	border-top: 1px solid var(--color-border);
	margin: 8px 0;
}

.track {
	display: flex;
	align-items: center;
	gap: 16px;
}

.track-art {
	background: #1e1e1e;
	border: 1px solid var(--color-border-strong);
	border-radius: 8px;
	flex-shrink: 0;
}

.track-art-large {
	width: 68px;
	height: 68px;
}

.track-art-small {
	width: 44px;
	height: 44px;
	border-radius: 6px;
}

.track-info {
	display: flex;
	flex-direction: column;
	gap: 4px;
	flex: 1;
	min-width: 0;
}

.track-title-large {
	font-size: 15px;
	font-weight: 500;
	color: var(--color-fg);
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.track-title-small {
	font-size: 13px;
	font-weight: 500;
	color: #dddddd;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.track-artist {
	font-family: var(--font-mono);
	font-size: 11px;
	color: #555555;
}

/* ── Right Stack ── */
.right-stack {
	width: 224px;
	flex-shrink: 0;
	display: flex;
	flex-direction: column;
	gap: 14px;

	@media (max-width: 600px) {
		width: 100%;
		flex-direction: row;
	}
}

/* ── Media Card (Book/Film) ── */
.media-card {
	display: flex;
	flex-direction: column;
	gap: 8px;
	flex: 1;
}

.media-card--horiz {
	flex-direction: row;
	align-items: center;
	gap: 16px;
	flex: 1;
}

.media-thumb {
	width: 100%;
	height: 90px;
	background: #1e1e1e;
	border: 1px solid #2a2a2a;
	border-radius: 8px;
	display: flex;
	align-items: center;
	justify-content: center;

	.media-card--horiz & {
		width: 64px;
		height: 64px;
		flex-shrink: 0;
	}
}

:global(.media-icon) {
	color: #383838;
}

.media-title {
	font-size: 14px;
	font-weight: 500;
	color: var(--color-fg);
	line-height: 1.3;
	white-space: pre-line;
}

.media-sub {
	font-family: var(--font-mono);
	font-size: 11px;
	color: #555555;
}

/* ── GitHub Card ── */
.github-card {
	flex: 1;
	display: flex;
	flex-direction: column;
	gap: 12px;
}

.github-header {
	display: flex;
	align-items: center;
	gap: 8px;
}

:global(.github-icon) {
	color: #444444;
}

.github-handle {
	font-family: var(--font-mono);
	font-size: 11px;
	color: #555555;
}

.contrib-grid {
	background: #0d1117;
	border-radius: 8px;
	padding: 12px;
	display: flex;
	flex-direction: column;
	gap: 3px;
	align-items: center;
}

.contrib-row {
	display: flex;
	gap: 3px;
}

.contrib-dot {
	width: 12px;
	height: 12px;
	border-radius: 3px;
}
</style>
