---
interface Props {
	city?: string
	coords?: string
	desc?: string
}

const {
	city = 'TOKYO,\nJAPAN',
	coords = '35.6762° N  139.6503° E',
	desc = 'Currently based in Tokyo.\nAvailable for remote work globally.',
} = Astro.props
---

<section class="location">
	<div class="location-card">
		<div class="loc-copy">
			<p class="loc-label">LOCATION</p>
			<h2 class="loc-city">{city}</h2>
			<p class="loc-coords">{coords}</p>
			<hr class="loc-divider">
			<p class="loc-desc">{desc}</p>
		</div>
		<div class="globe-wrap">
			<svg
				viewBox="0 0 300 300"
				xmlns="http://www.w3.org/2000/svg"
				class="globe-svg"
				aria-hidden="true"
			>
				<defs>
					<clipPath id="gc">
						<circle cx="150" cy="150" r="148" />
					</clipPath>
				</defs>
				<!-- Background -->
				<circle
					cx="150"
					cy="150"
					r="149"
					fill="#080808"
					stroke="#333333"
					stroke-width="1"
				/>
				<g clip-path="url(#gc)">
					<!-- Latitude rings -->
					<ellipse
						cx="150"
						cy="60"
						rx="90"
						ry="10"
						fill="none"
						stroke="#252525"
						stroke-width="1"
					/>
					<ellipse
						cx="150"
						cy="100"
						rx="135"
						ry="16"
						fill="none"
						stroke="#252525"
						stroke-width="1"
					/>
					<ellipse
						cx="150"
						cy="150"
						rx="149"
						ry="22"
						fill="none"
						stroke="#2e2e2e"
						stroke-width="1"
					/>
					<ellipse
						cx="150"
						cy="200"
						rx="135"
						ry="16"
						fill="none"
						stroke="#252525"
						stroke-width="1"
					/>
					<ellipse
						cx="150"
						cy="240"
						rx="90"
						ry="10"
						fill="none"
						stroke="#252525"
						stroke-width="1"
					/>
					<!-- Longitude lines -->
					<ellipse
						cx="70"
						cy="150"
						rx="18"
						ry="148"
						fill="none"
						stroke="#252525"
						stroke-width="1"
					/>
					<ellipse
						cx="150"
						cy="150"
						rx="28"
						ry="148"
						fill="none"
						stroke="#252525"
						stroke-width="1"
					/>
					<ellipse
						cx="230"
						cy="150"
						rx="18"
						ry="148"
						fill="none"
						stroke="#252525"
						stroke-width="1"
					/>
					<!-- Tokyo dot -->
					<circle cx="143" cy="56" r="7" fill="#D71921" />
				</g>
				<!-- Tokyo label -->
				<text
					x="161"
					y="65"
					font-family="'Space Mono', monospace"
					font-size="9"
					fill="#D71921"
					letter-spacing="2"
				>
					TYO
				</text>
			</svg>
		</div>
	</div>
</section>

<style>
.location {
	padding: 40px 80px;

	@media (max-width: 768px) {
		padding: 40px 24px;
	}
}

.location-card {
	background: var(--color-bg-card);
	border: 1px solid var(--color-border);
	border-radius: 12px;
	padding: 32px 40px;
	display: flex;
	align-items: center;
	gap: 80px;

	@media (max-width: 768px) {
		flex-direction: column;
		gap: 32px;
		padding: 24px;
	}
}

.loc-copy {
	display: flex;
	flex-direction: column;
	gap: 12px;
	flex: 1;
}

.loc-label {
	font-family: var(--font-mono);
	font-size: 11px;
	color: var(--color-fg-muted);
	letter-spacing: 8px;
	text-transform: uppercase;
}

.loc-city {
	font-family: var(--font-display);
	font-size: clamp(36px, 4vw, 56px);
	font-weight: 400;
	color: var(--color-fg);
	white-space: pre-line;
	line-height: 1;
}

.loc-coords {
	font-family: var(--font-mono);
	font-size: 12px;
	color: #444444;
}

.loc-divider {
	border: none;
	border-top: 1px solid var(--color-border);
	width: 300px;
	max-width: 100%;
	margin: 0;
}

.loc-desc {
	font-size: 14px;
	color: var(--color-fg-muted);
	line-height: 1.6;
	white-space: pre-line;
	max-width: 300px;
}

.globe-wrap {
	flex-shrink: 0;
	width: 300px;
	height: 300px;
	border-radius: 50%;
	overflow: hidden;

	@media (max-width: 768px) {
		width: 200px;
		height: 200px;
	}
}

.globe-svg {
	width: 100%;
	height: 100%;
}
</style>
