---
import { ArrowUpRight } from 'lucide-astro'

interface Project {
	title: string
	description: string
	tags: string[]
	href: string
	client?: string
	year?: string
	badge?: string
}

interface Props {
	projects: Project[]
}

const { projects } = Astro.props
---

<section class="projects">
	<div class="proj-header">
		<div class="proj-header-left">
			<div class="accent-bar"></div>
			<p class="proj-sub">SELECTED PROJECTS</p>
			<h2 class="proj-title">FEATURED<br>WORK</h2>
		</div>
		<a href="/work" class="proj-more">VIEW ALL →</a>
	</div>

	<div class="proj-grid">
		{projects.map(({ title, description, tags, href, client, year, badge }) => (
			<a href={href} class="proj-card">
				{tags.length > 0 && (
					<div class="proj-tags">
						{tags.slice(0, 3).map((tag) => (
							<span class="proj-tag">{tag}</span>
						))}
					</div>
				)}
				<h3 class="proj-card-title">{title}</h3>
				{(client || year) && (
					<p class="proj-meta">
						{client && <span>{client}</span>}
						{client && year && <span class="meta-sep">·</span>}
						{year && <span>{year}</span>}
					</p>
				)}
				{description && (
					<p class="proj-desc">{description}</p>
				)}
				{badge && (
					<span class="proj-badge">{badge}</span>
				)}
				<div class="proj-link">
					<ArrowUpRight size={14} aria-hidden="true" />
					<span>VIEW PROJECT →</span>
				</div>
			</a>
		))}
	</div>
</section>

<style>
.projects {
	padding: 70px 80px;
	display: flex;
	flex-direction: column;
	gap: 40px;

	@media (max-width: 768px) {
		padding: 48px 24px;
	}
}

.proj-header {
	display: flex;
	align-items: flex-end;
	justify-content: space-between;
	gap: 16px;
}

.proj-header-left {
	display: flex;
	flex-direction: column;
	gap: 8px;
}

.accent-bar {
	width: 60px;
	height: 4px;
	background: var(--color-fg);
	border-radius: 2px;
}

.proj-sub {
	font-family: var(--font-mono);
	font-size: 11px;
	color: var(--color-fg-muted);
	letter-spacing: 2px;
}

.proj-title {
	font-size: 34px;
	font-weight: 300;
	color: var(--color-fg);
	line-height: 1;
}

.proj-more {
	font-family: var(--font-mono);
	font-size: 11px;
	font-weight: 600;
	color: var(--color-fg-secondary);
	letter-spacing: 2px;
	text-decoration: none;
	flex-shrink: 0;
	padding-bottom: 4px;

	&:hover {
		opacity: 0.6;
		text-decoration: none;
	}
}

.proj-grid {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 16px;

	@media (max-width: 768px) {
		grid-template-columns: 1fr;
	}
}

.proj-card:last-child:nth-child(odd) {
	grid-column: span 2;

	@media (max-width: 768px) {
		grid-column: span 1;
	}
}

.proj-card {
	background: var(--color-bg-card);
	border: 1px solid var(--color-border);
	border-radius: 12px;
	padding: 24px;
	display: flex;
	flex-direction: column;
	gap: 12px;
	text-decoration: none;
	color: inherit;
	transition: border-color 200ms ease;

	&:hover {
		border-color: var(--color-border-strong);
		opacity: 1;
		text-decoration: none;
	}
}

.proj-tags {
	display: flex;
	gap: 8px;
	flex-wrap: wrap;
}

.proj-tag {
	font-family: var(--font-mono);
	font-size: 10px;
	font-weight: 600;
	color: var(--color-fg-muted);
	background: var(--color-bg);
	border: 1px solid var(--color-border-strong);
	border-radius: 4px;
	padding: 4px 10px;
}

.proj-card-title {
	font-size: 17px;
	font-weight: 500;
	color: var(--color-fg);
	line-height: 1.3;
}

.proj-meta {
	font-family: var(--font-mono);
	font-size: 11px;
	color: var(--color-fg-muted);
	display: flex;
	align-items: center;
	gap: 6px;
}

.meta-sep {
	color: var(--color-border-strong);
}

.proj-desc {
	font-size: 13px;
	color: var(--color-fg-muted);
	line-height: 1.5;
	flex: 1;
}

.proj-badge {
	font-family: var(--font-mono);
	font-size: 10px;
	font-weight: 600;
	color: var(--color-fg-secondary);
	background: var(--color-bg);
	border: 1px solid var(--color-border-strong);
	border-radius: 4px;
	padding: 4px 10px;
	align-self: flex-start;
}

.proj-link {
	display: flex;
	align-items: center;
	gap: 6px;
	font-family: var(--font-mono);
	font-size: 11px;
	font-weight: 600;
	color: var(--color-fg-muted);
	letter-spacing: 1px;
	margin-top: 4px;
}
</style>
