---
import { Font } from 'astro:assets'
import { getMenu, getSiteSettings } from 'emdash'
import { createPublicPageContext } from 'emdash/page'
import { EmDashHead } from 'emdash/ui'
import '../styles/style.css'

import Header from '../components/Header.svelte'

interface Props {
	title?: string
	description?: string
	image?: string
	type?: 'website' | 'article'
}

const { title, description, image, type = 'website' } = Astro.props
const hasSidebar = Astro.slots.has('sidebar')
const settings = await getSiteSettings()
const siteTitle = settings?.title || 'Studio'
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle
const siteDescription = settings?.tagline || 'Design & Development'

const menu = await getMenu('primary')

const pageCtx = createPublicPageContext({
	Astro,
	kind: 'custom',
	pageType: type,
	title: fullTitle,
	description: description || siteDescription,
	canonical: Astro.url.href,
	image,
	seo: { ogImage: image },
	siteName: siteTitle,
})
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<Font cssVariable="--font-doto" />
		<Font cssVariable="--font-space-mono" />
		<Font cssVariable="--font-noto-sans-jp" />
		<link
			rel="alternate"
			type="application/rss+xml"
			title={`${siteTitle} RSS Feed`}
			href="/rss.xml"
		>
	</head>
	<body>
		{hasSidebar ? (
			<div class="layout-sidebar-page">
				<aside class="layout-sidebar">
					<slot name="sidebar" />
				</aside>
				<div class="layout-main">
					<Header client:load />
					<main><slot /></main>
				</div>
			</div>
		) : (
			<>
				<Header client:load />
				<main><slot /></main>
			</>
		)}
	</body>
</html>

<style>
.layout-sidebar-page {
	display: flex;
	align-items: flex-start;
	min-height: 100vh;
	gap: 32px;
	padding: 32px;
	background: var(--color-bg);
	box-sizing: border-box;

	@media (max-width: 768px) {
		flex-direction: column;
		padding: 0;
		gap: 0;
	}
}

.layout-sidebar {
	width: 390px;
	flex-shrink: 0;
	position: sticky;
	top: 32px;
	max-height: calc(100vh - 64px);
	border-radius: 54px;
	overflow: hidden;

	@media (max-width: 768px) {
		width: 100%;
		position: relative;
		top: auto;
		max-height: none;
		border-radius: 0;
	}
}

.layout-main {
	flex: 1;
	min-width: 0;
	background: var(--color-bg);
	border-radius: 16px;
	overflow: hidden;

	@media (max-width: 768px) {
		border-radius: 0;
	}
}
</style>
